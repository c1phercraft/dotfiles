#
# Git aliases.
#

git config --global alias.co 'checkout'
git config --global alias.com 'checkout master'
git config --global alias.cob 'checkout -b'
git config --global alias.c 'commit -m'
git config --global alias.amend 'commit --amend'
# Short status overview.
git config --global alias.s '!git status --short --branch'
# Unstage files already staged.
git config --global alias.unstage 'reset -q HEAD --'
# Get rid of any changes you made.
git config --global alias.discard 'checkout --'
# Sync your current branch with the master one.
git config --global alias.sync '!git fetch origin && git rebase origin/master'
# Prunes refs to deleted remote branches.
git config --global alias.prune 'fetch -p'

# Check staged changes before committing.
git config --global alias.precommit 'diff --cached --color-words --diff-algorithm=minimal -w'
# Better diff output.
git config --global alias.d 'diff --color-words'
# Show difference since/from branch point.
git config --global alias.dm 'diff --color-words origin/master... --'
# Show files touched since/from branch point.
git config --global alias.touched 'diff --name-status origin/master... --'

# Find files in repo.
git config --global alias.ff '!git ls-files | grep -sI --color=auto'
# Find text in files in repo.
git config --global alias.fs '!git ls-files -z | xargs -0 grep -snI --color=auto'
# Find text in commit message history.
git config --global alias.fc '!git log --pretty="format:%C(bold green)%h%C(reset) - %C(dim white)%an%C(reset) - %C(white)%s%C(reset)" --name-status --grep'

# %d - Branch
# %h - SHA1
# %s - Summary
# %an - Name of committer
# %ar - Relative time

# List commits as a tree.
git config --global alias.tree 'log --graph --abbrev-commit --decorate --date=relative --format=format:"%C(bold green)%h%C(reset) - %C(bold blue)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)" --all'
# List commits.
git config --global alias.ls 'log --format=format:"%C(bold green)%h%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)"'
# List commits, also showing files touched.
git config --global alias.ll 'log --decorate --stat --format=format:"%C(bold green)%h%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)"'
# List commit history of a single file.
git config --global alias.h 'log --oneline --follow --format=format:"%C(bold green)%h%C(reset) %C(bold blue)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)"'
# List files with conflicts
git config --global alias.conflicts 'diff --name-only --diff-filter=U'

# Run Vim for a file path, starting at root of repo.
git config --global alias.vi '!vim $1'

# vim: ft=sh
